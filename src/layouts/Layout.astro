---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <link rel="manifest" href="/cancionero/manifest.webmanifest">
  <meta name="theme-color" content="#C9A227">
</head>
<body>
  <slot />
  <script>
    if ('serviceWorker' in navigator) {
      navigator.serviceWorker.register('/cancionero/sw.js').catch(()=>{});
    }
  </script>
</body>
</html>
