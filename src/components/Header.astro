---
// Componente de cabecera del cancionero
import OfflineDownload from './OfflineDownload.astro';
---

<header class="site-header">
  <p class="eyebrow">Cancionero para ukelele</p>
  <h1 class="site-title">Boleros para Cantar</h1>
  <p class="site-sub">Letra completa, cifrado y diagramas de acordes interactivos</p>
  <OfflineDownload />
</header>

<style>
  .site-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--marfil-tenue);
    margin: 0 0 14px;
  }

  .site-title {
    font-family: var(--font-display);
    font-optical-sizing: auto;
    font-weight: 600;
    font-size: clamp(32px, 6vw, 48px);
    line-height: 1.05;
    margin: 0 0 10px;
    color: var(--marfil);
    letter-spacing: 0.3px;
  }

  .site-sub {
    font-size: 15px;
    color: var(--marfil-tenue);
    font-style: italic;
    margin: 0;
  }
</style>
