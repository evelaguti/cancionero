---
import ChordLibrary from './ChordLibrary.astro';
import LyricSheet from './LyricSheet.astro';

interface Props {
  song: any;
  isActive: boolean;
}

const { song, isActive } = Astro.props;

const accents = {
  reloj: { accent: "var(--oro-viejo)", accentLight: "var(--oro-claro)" },
  llorando: { accent: "var(--azul-llanto)", accentLight: "var(--azul-claro)" },
  tratame: { accent: "var(--rosa-suave)", accentLight: "var(--rosa-claro)" },
  ayer: { accent: "var(--lila-nostalgia)", accentLight: "var(--lila-claro)" },
  amor: { accent: "var(--oro-viejo)", accentLight: "var(--oro-claro)" },
  valparaiso: { accent: "var(--azul-llanto)", accentLight: "var(--azul-claro)" },
  flaca: { accent: "var(--rosa-suave)", accentLight: "var(--rosa-claro)" },
  barca: { accent: "var(--azul-llanto)", accentLight: "var(--azul-claro)" },
  contigo: { accent: "var(--rosa-suave)", accentLight: "var(--rosa-claro)" },
  quierodormircansado: { accent: "var(--lila-nostalgia)", accentLight: "var(--lila-claro)" },
  lajoyadelpacifico: { accent: "var(--azul-llanto)", accentLight: "var(--azul-claro)" },
  corazondelator: { accent: "var(--rosa-suave)", accentLight: "var(--rosa-claro)" },
  demusicaligera: { accent: "var(--oro-viejo)", accentLight: "var(--oro-claro)" },
  persianaamericana: { accent: "var(--azul-llanto)", accentLight: "var(--azul-claro)" },
  signos: { accent: "var(--lila-nostalgia)", accentLight: "var(--lila-claro)" },
  nadapersonal: { accent: "var(--rosa-suave)", accentLight: "var(--rosa-claro)" },
}[song.id] || { accent: "var(--oro-viejo)", accentLight: "var(--oro-claro)" };

const defaultSpeeds = {
  reloj: 18,
  llorando: 19,
  tratame: 22,
  ayer: 18,
  amor: 20,
  valparaiso: 24,
  flaca: 28,
  barca: 18,
  contigo: 19,
  perfidia: 22,
  copa: 20,
  abrazame: 22,
  fidelidad: 18,
  asifue: 22,
  almacorazon: 20,
  quierodormircansado: 22,
  lajoyadelpacifico: 22,
  corazondelator: 22,
  demusicaligera: 24,
  persianaamericana: 24,
  signos: 22,
  nadapersonal: 24
};

const songSpeed = song.scrollSpeed || defaultSpeeds[song.id] || 20;
---

<section 
  class={`song-panel ${isActive ? 'active' : ''}`} 
  id={`panel-${song.id}`} 
  data-song={song.id} 
  role="tabpanel" 
  aria-labelledby={`tab-${song.id}`}
  style={`--accent: ${accents.accent}; --accent-light: ${accents.accentLight};`}
>
  <div class="song-head">
    {song.id === "reloj" && (
      <svg class="clock-motif" viewBox="0 0 54 54">
        <circle class="clock-face" cx="27" cy="27" r="21"/>
        <line class="clock-tick" x1="27" y1="8" x2="27" y2="11"/>
        <line class="clock-tick" x1="27" y1="43" x2="27" y2="46"/>
        <line class="clock-tick" x1="8" y1="27" x2="11" y2="27"/>
        <line class="clock-tick" x1="43" y1="27" x2="46" y2="27"/>
        <line class="clock-hand-hr" x1="27" y1="27" x2="27" y2="17"/>
        <line class="clock-hand-min" x1="27" y1="27" x2="34" y2="27"/>
        <line class="clock-hand-sec" x1="27" y1="27" x2="27" y2="14"/>
        <circle cx="27" cy="27" r="1.4" fill="var(--marfil)"/>
      </svg>
    )}
    {song.id === "llorando" && (
      <div class="rain-motif" data-rain></div>
    )}
    <p class="song-genre">{song.genre}</p>
    <h2 class="song-title">{song.title}</h2>
    <span class="tono-badge">{song.suggestedKey}</span>
  </div>

  <ChordLibrary chords={song.chordsUsed} />

  <!-- Karaoke Controls -->
  <div class="karaoke-controls" data-song-id={song.id} data-base-speed={songSpeed}>
    <div class="player-buttons">
      <button type="button" class="karaoke-btn play-pause-btn" aria-label="Reproducir desplazamiento automático" title="Reproducir">
        <svg class="play-icon" viewBox="0 0 24 24" fill="currentColor">
          <path d="M8 5v14l11-7z"/>
        </svg>
        <svg class="pause-icon" viewBox="0 0 24 24" fill="currentColor" style="display: none;">
          <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/>
        </svg>
      </button>
      
      <button type="button" class="karaoke-btn stop-btn" aria-label="Detener y reiniciar" title="Detener">
        <svg viewBox="0 0 24 24" fill="currentColor">
          <path d="M6 6h12v12H6z"/>
        </svg>
      </button>
    </div>
    
    <div class="speed-container">
      <span class="speed-label">Velocidad:</span>
      <input 
        type="range" 
        min="0.5" 
        max="2.5" 
        step="0.1" 
        value="1.0" 
        class="speed-slider" 
        aria-label="Ajustar velocidad de desplazamiento"
      />
      <span class="speed-display">1.0x</span>
    </div>
  </div>

  <LyricSheet blocks={song.blocks} />
</section>

<style>
  .song-panel {
    display: none;
    animation: fadeIn 0.45s ease;
  }
  .song-panel.active {
    display: block;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(6px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .song-head {
    position: relative;
    padding: 38px 10px 28px;
    text-align: center;
    overflow: hidden;
    border-bottom: 1px solid rgba(239, 227, 206, 0.1);
  }

  .song-genre {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--accent-light);
    margin: 0 0 10px;
  }

  .song-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(26px, 5vw, 38px);
    margin: 0 0 14px;
    color: var(--marfil);
  }

  .tono-badge {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--accent-light);
    border: 1px solid var(--accent);
    border-radius: 999px;
    padding: 5px 16px;
    background: rgba(239, 227, 206, 0.03);
  }

  /* clock signature (song 1) */
  .clock-motif {
    position: absolute;
    top: 18px;
    right: 22px;
    width: 54px;
    height: 54px;
    opacity: 0.85;
  }
  .clock-face { fill: none; stroke: var(--marfil-tenue); stroke-width: 1.4; }
  .clock-tick { stroke: var(--marfil-tenue); stroke-width: 1.2; }
  .clock-hand-hr { stroke: var(--marfil); stroke-width: 2; stroke-linecap: round; }
  .clock-hand-min { stroke: var(--marfil); stroke-width: 1.6; stroke-linecap: round; }
  .clock-hand-sec {
    stroke: var(--oro-viejo);
    stroke-width: 1;
    stroke-linecap: round;
    transform-origin: 27px 27px;
    animation: stopTime 3.6s cubic-bezier(.25, .9, .3, 1) 1 forwards;
  }
  @keyframes stopTime {
    from { transform: rotate(0deg); }
    to { transform: rotate(340deg); }
  }

  /* rain / tears signature (song 2) */
  .rain-motif {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    overflow: hidden;
  }
  :global(.rain-drop) {
    position: absolute;
    top: -30px;
    width: 1.5px;
    height: 22px;
    background: linear-gradient(to bottom, transparent, var(--azul-llanto));
    opacity: 0.35;
    animation: fall 5.5s linear infinite;
  }
  @keyframes fall {
    0% { transform: translateY(0); opacity: 0; }
    12% { opacity: 0.4; }
    85% { opacity: 0.25; }
    100% { transform: translateY(120px); opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .clock-hand-sec { animation: none; transform: rotate(300deg); }
    :global(.rain-drop) { animation: none; display: none; }
    .song-panel { animation: none; }
  }

  @media (max-width: 480px) {
    .clock-motif { width: 42px; height: 42px; top: 12px; right: 14px; }
  }

  /* Karaoke controls inline player */
  .karaoke-controls {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    background: rgba(239, 227, 206, 0.03);
    border: 1px solid rgba(239, 227, 206, 0.08);
    border-radius: 12px;
    padding: 12px 20px;
    margin: 28px 0 10px;
    box-shadow: inset 0 1px 2px rgba(239, 227, 206, 0.02);
  }

  .player-buttons {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .karaoke-btn {
    background: transparent;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--marfil);
    transition: all 0.2s ease;
    padding: 0;
    flex-shrink: 0;
  }

  .karaoke-btn:hover {
    color: var(--accent-light);
    transform: scale(1.05);
  }

  .karaoke-btn:active {
    transform: scale(0.95);
  }

  .play-pause-btn {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: var(--accent);
    color: var(--vinilo);
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.15);
  }

  .play-pause-btn:hover {
    background: var(--accent-light);
    color: var(--vinilo);
    box-shadow: 0 0 10px var(--accent);
  }

  .play-pause-btn svg {
    width: 20px;
    height: 20px;
  }

  .stop-btn {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    border: 1px solid rgba(239, 227, 206, 0.2);
    background: rgba(239, 227, 206, 0.03);
    color: var(--marfil-tenue);
  }

  .stop-btn:hover {
    border-color: var(--accent);
    color: var(--accent-light);
    background: rgba(239, 227, 206, 0.08);
  }

  .stop-btn svg {
    width: 15px;
    height: 15px;
  }

  .speed-container {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-grow: 1;
    max-width: 260px;
  }

  .speed-label {
    font-size: 12px;
    color: var(--marfil-tenue);
    font-family: var(--font-body);
    font-weight: 500;
  }

  .speed-slider {
    flex-grow: 1;
    -webkit-appearance: none;
    appearance: none;
    height: 4px;
    border-radius: 2px;
    background: rgba(239, 227, 206, 0.15);
    outline: none;
    cursor: pointer;
  }

  .speed-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--accent);
    transition: transform 0.15s ease, background-color 0.15s ease;
  }

  .speed-slider::-webkit-slider-thumb:hover {
    transform: scale(1.25);
    background: var(--accent-light);
  }

  .speed-slider::-moz-range-thumb {
    width: 12px;
    height: 12px;
    border: none;
    border-radius: 50%;
    background: var(--accent);
    transition: transform 0.15s ease, background-color 0.15s ease;
    cursor: pointer;
  }

  .speed-slider::-moz-range-thumb:hover {
    transform: scale(1.25);
    background: var(--accent-light);
  }

  .speed-display {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--marfil-tenue);
    min-width: 36px;
    text-align: right;
  }

  @media (max-width: 520px) {
    .karaoke-controls {
      flex-direction: column;
      align-items: stretch;
      gap: 12px;
      padding: 12px 14px;
    }
    .speed-container {
      max-width: none;
      border-top: 1px solid rgba(239, 227, 206, 0.08);
      padding-top: 10px;
    }
  }
</style>
