---
// Componente de pestañas de navegación (TabList)
---

<nav class="tablist" role="tablist" aria-label="Seleccionar canción">
  <button class="tab-btn tab-reloj active" role="tab" aria-selected="true" aria-controls="panel-reloj" data-song="reloj">
    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.6"/>
      <path d="M12 7v5l3.2 2" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
    </svg>
    El Reloj
  </button>

  <button class="tab-btn tab-llorando" role="tab" aria-selected="false" aria-controls="panel-llorando" data-song="llorando">
    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M12 3C12 3 6 10.5 6 15a6 6 0 0 0 12 0c0-4.5-6-12-6-12z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
    </svg>
    Déjenme si estoy llorando
  </button>

  <button class="tab-btn tab-tratame" role="tab" aria-selected="false" aria-controls="panel-tratame" data-song="tratame">
    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M12 20s-7.2-4.4-9.8-9.1C.6 8 1.7 4.8 4.7 4C7 3.4 9.4 4.4 12 7c2.6-2.6 5-3.6 7.3-3C22.3 4.8 23.4 8 21.8 10.9 19.2 15.6 12 20 12 20z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
    </svg>
    Trátame suavemente
  </button>

  <button class="tab-btn tab-ayer" role="tab" aria-selected="false" aria-controls="panel-ayer" data-song="ayer">
    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M4 6h16v11H9l-5 3.5V6z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
      <line x1="7.5" y1="10" x2="16.5" y2="10" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
      <line x1="7.5" y1="13.2" x2="14" y2="13.2" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
    </svg>
    Ayer preguntaron por ti
  </button>

  <button class="tab-btn tab-amor" role="tab" aria-selected="false" aria-controls="panel-amor" data-song="amor">
    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
    </svg>
    Te he prometido
  </button>

  <button class="tab-btn tab-valparaiso" role="tab" aria-selected="false" aria-controls="panel-valparaiso" data-song="valparaiso">
    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M12 3v12" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
      <circle cx="12" cy="18" r="3" stroke="currentColor" stroke-width="1.6"/>
      <path d="M12 3c2.2 0 4 1 5.5 2.3M12 3c-2.2 0-4 1-5.5 2.3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
    </svg>
    Valparaíso
  </button>

  <button class="tab-btn tab-flaca" role="tab" aria-selected="false" aria-controls="panel-flaca" data-song="flaca">
    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M8 5.5h8" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
      <path d="M12 5.5V2" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
      <path d="M7 21l5-7 5 7" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
      <circle cx="9" cy="17" r="2" stroke="currentColor" stroke-width="1.6"/>
      <circle cx="15" cy="17" r="2" stroke="currentColor" stroke-width="1.6"/>
    </svg>
    Flaca
  </button>

  <button class="tab-btn tab-barca" role="tab" aria-selected="false" aria-controls="panel-barca" data-song="barca">
    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M3 14h18l-2 5H5l-2-5z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
      <path d="M12 3v11" stroke="currentColor" stroke-width="1.6"/>
      <path d="M12 4.5l6 6.5h-6V4.5z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
    </svg>
    La Barca
  </button>

  <button class="tab-btn tab-contigo" role="tab" aria-selected="false" aria-controls="panel-contigo" data-song="contigo">
    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="9" cy="12" r="5" stroke="currentColor" stroke-width="1.6"/>
      <circle cx="15" cy="12" r="5" stroke="currentColor" stroke-width="1.6"/>
    </svg>
    Contigo
  </button>

  <button class="tab-btn tab-perfidia" role="tab" aria-selected="false" aria-controls="panel-perfidia" data-song="perfidia">
    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
      <path d="M12 5.5l-2 4 4 2.5-3 5.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    Perfidia
  </button>

  <button class="tab-btn tab-copa" role="tab" aria-selected="false" aria-controls="panel-copa" data-song="copa">
    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M17 3H7c0 0 0 8 5 8s5-8 5-8z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
      <path d="M12 11v8M9 19h6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
      <path d="M12 3l-1.5 3.5 2.5 1-2 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    La Copa Rota
  </button>

  <button class="tab-btn tab-abrazame" role="tab" aria-selected="false" aria-controls="panel-abrazame" data-song="abrazame">
    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M9 17.5l-1-.9c-3.2-2.9-5.3-5-5.3-7.6C2.7 6.4 4.8 4.7 7 4.7c1.2 0 2.4.6 3.1 1.5.8-.9 2-1.5 3.2-1.5 2.2 0 4.3 1.7 4.3 4.3 0 2.6-2.1 4.7-5.3 7.6l-1 .9z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" opacity="0.65"/>
      <path d="M15 19.5l-1-.9c-3.2-2.9-5.3-5-5.3-7.6 0-2.6 2.1-4.3 4.3-4.3 1.2 0 2.4.6 3.1 1.5.8-.9 2-1.5 3.2-1.5 2.2 0 4.3 1.7 4.3 4.3 0 2.6-2.1 4.7-5.3 7.6l-1 .9z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
    </svg>
    Abrázame muy fuerte
  </button>

  <button class="tab-btn tab-fidelidad" role="tab" aria-selected="false" aria-controls="panel-fidelidad" data-song="fidelidad">
    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M12 3a9 9 0 1 0 9 9c0-.46-.04-.92-.1-1.36a7 7 0 1 1-7.64-7.64c.44.06.9.1 1.36.1A9 9 0 0 0 12 3z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
      <circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.6"/>
      <path d="M12 6V4M12 20v-2M6 12H4M20 12h-2" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
    </svg>
    Oh tu fidelidad
  </button>

  <button class="tab-btn tab-asifue" role="tab" aria-selected="false" aria-controls="panel-asifue" data-song="asifue">
    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M12 18.5c-3.5-3.5-6-3-9-5 4-1 7 .5 9 2.5 2-2 5-3.5 9-2.5-3 2-5.5 1.5-9 5z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
      <path d="M12 13.5c-1-3-3.5-6-6-7.5 2 2 3.5 5 4 7.5" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
    </svg>
    Así fue
  </button>

  <button class="tab-btn tab-almacorazon" role="tab" aria-selected="false" aria-controls="panel-almacorazon" data-song="almacorazon">
    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
      <path d="M6 10h3l1.5-3.5L12 14.5l1.5-5.5L16.5 10h1.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M4 6.5l.5.5-.5.5-.5-.5zM20 6.5l.5.5-.5.5-.5-.5z" fill="currentColor"/>
    </svg>
    Alma, corazón y vida
  </button>

  <button class="tab-btn tab-quierodormircansado" role="tab" aria-selected="false" aria-controls="panel-quierodormircansado" data-song="quierodormircansado">
    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
    </svg>
    Quiero dormir cansado
  </button>

  <button class="tab-btn tab-afinador" role="tab" aria-selected="false" aria-controls="panel-afinador" data-song="afinador">
    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M12 3v12" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
      <circle cx="12" cy="18" r="3" stroke="currentColor" stroke-width="1.6"/>
      <path d="M12 3c2.2 0 4 1 5.5 2.3M12 3c-2.2 0-4 1-5.5 2.3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
    </svg>
    Afinador
  </button>
</nav>

<style>
  .tablist {
    display: flex;
    flex-wrap: wrap;
    gap: 4px 10px;
    margin: 36px 0 0;
    border-bottom: 1px solid rgba(239, 227, 206, 0.15);
  }

  .tab-btn {
    flex: 1 1 150px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 9px;
    background: transparent;
    border: none;
    border-bottom: 3px solid transparent;
    color: var(--marfil-tenue);
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 14px;
    padding: 14px 8px 16px;
    cursor: pointer;
    transition: color 0.25s ease, border-color 0.25s ease;
    border-radius: 6px 6px 0 0;
  }

  .tab-btn svg {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    opacity: 0.75;
    transition: opacity .25s ease;
  }

  .tab-btn:hover {
    color: var(--marfil);
    background: rgba(239, 227, 206, 0.04);
  }

  .tab-btn.tab-reloj.active { color: var(--oro-claro); border-color: var(--oro-viejo); }
  .tab-btn.tab-reloj.active svg { opacity: 1; }

  .tab-btn.tab-llorando.active { color: var(--azul-claro); border-color: var(--azul-llanto); }
  .tab-btn.tab-llorando.active svg { opacity: 1; }

  .tab-btn.tab-tratame.active { color: var(--rosa-claro); border-color: var(--rosa-suave); }
  .tab-btn.tab-tratame.active svg { opacity: 1; }

  .tab-btn.tab-ayer.active { color: var(--lila-claro); border-color: var(--lila-nostalgia); }
  .tab-btn.tab-ayer.active svg { opacity: 1; }

  .tab-btn.tab-amor.active { color: var(--oro-claro); border-color: var(--oro-viejo); }
  .tab-btn.tab-amor.active svg { opacity: 1; }

  .tab-btn.tab-valparaiso.active { color: var(--azul-claro); border-color: var(--azul-llanto); }
  .tab-btn.tab-valparaiso.active svg { opacity: 1; }

  .tab-btn.tab-flaca.active { color: var(--lila-claro); border-color: var(--lila-nostalgia); }
  .tab-btn.tab-flaca.active svg { opacity: 1; }

  .tab-btn.tab-barca.active { color: var(--azul-claro); border-color: var(--azul-llanto); }
  .tab-btn.tab-barca.active svg { opacity: 1; }

  .tab-btn.tab-contigo.active { color: var(--rosa-claro); border-color: var(--rosa-suave); }
  .tab-btn.tab-contigo.active svg { opacity: 1; }

  .tab-btn.tab-perfidia.active { color: var(--rosa-claro); border-color: var(--rosa-suave); }
  .tab-btn.tab-perfidia.active svg { opacity: 1; }

  .tab-btn.tab-copa.active { color: var(--oro-claro); border-color: var(--oro-viejo); }
  .tab-btn.tab-copa.active svg { opacity: 1; }

  .tab-btn.tab-abrazame.active { color: var(--lila-claro); border-color: var(--lila-nostalgia); }
  .tab-btn.tab-abrazame.active svg { opacity: 1; }

  .tab-btn.tab-fidelidad.active { color: var(--verde-claro); border-color: var(--verde-uke); }
  .tab-btn.tab-fidelidad.active svg { opacity: 1; }

  .tab-btn.tab-asifue.active { color: var(--azul-claro); border-color: var(--azul-llanto); }
  .tab-btn.tab-asifue.active svg { opacity: 1; }

  .tab-btn.tab-almacorazon.active { color: var(--rosa-claro); border-color: var(--rosa-suave); }
  .tab-btn.tab-almacorazon.active svg { opacity: 1; }

  .tab-btn.tab-quierodormircansado.active { color: var(--lila-claro); border-color: var(--lila-nostalgia); }
  .tab-btn.tab-quierodormircansado.active svg { opacity: 1; }

  .tab-btn.tab-afinador.active { color: var(--verde-claro); border-color: var(--verde-uke); }
  .tab-btn.tab-afinador.active svg { opacity: 1; }

  .tab-btn:focus-visible {
    outline: 2px solid var(--marfil);
    outline-offset: 2px;
  }

  @media (max-width: 480px) {
    .tab-btn {
      font-size: 12.5px;
      padding: 12px 4px 14px;
      gap: 6px;
    }
    .tab-btn svg {
      width: 15px;
      height: 15px;
    }
  }
</style>
