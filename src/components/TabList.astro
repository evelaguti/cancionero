---
// Componente de pestañas de navegación (TabList)
---

<nav class="tablist" role="tablist" aria-label="Seleccionar canción">
  <button class="tab-btn tab-reloj active" role="tab" aria-selected="true" aria-controls="panel-reloj" data-song="reloj">
    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.6"/>
      <path d="M12 7v5l3.2 2" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
    </svg>
    El Reloj
  </button>

  <button class="tab-btn tab-llorando" role="tab" aria-selected="false" aria-controls="panel-llorando" data-song="llorando">
    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M12 3C12 3 6 10.5 6 15a6 6 0 0 0 12 0c0-4.5-6-12-6-12z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
    </svg>
    Déjenme si estoy llorando
  </button>

  <button class="tab-btn tab-tratame" role="tab" aria-selected="false" aria-controls="panel-tratame" data-song="tratame">
    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M12 20s-7.2-4.4-9.8-9.1C.6 8 1.7 4.8 4.7 4C7 3.4 9.4 4.4 12 7c2.6-2.6 5-3.6 7.3-3C22.3 4.8 23.4 8 21.8 10.9 19.2 15.6 12 20 12 20z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
    </svg>
    Trátame suavemente
  </button>

  <button class="tab-btn tab-ayer" role="tab" aria-selected="false" aria-controls="panel-ayer" data-song="ayer">
    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M4 6h16v11H9l-5 3.5V6z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
      <line x1="7.5" y1="10" x2="16.5" y2="10" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
      <line x1="7.5" y1="13.2" x2="14" y2="13.2" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
    </svg>
    Ayer preguntaron por ti
  </button>

  <button class="tab-btn tab-amor" role="tab" aria-selected="false" aria-controls="panel-amor" data-song="amor">
    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
    </svg>
    Te he prometido
  </button>

  <button class="tab-btn tab-valparaiso" role="tab" aria-selected="false" aria-controls="panel-valparaiso" data-song="valparaiso">
    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M12 3v12" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
      <circle cx="12" cy="18" r="3" stroke="currentColor" stroke-width="1.6"/>
      <path d="M12 3c2.2 0 4 1 5.5 2.3M12 3c-2.2 0-4 1-5.5 2.3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
    </svg>
    Valparaíso
  </button>

  <button class="tab-btn tab-flaca" role="tab" aria-selected="false" aria-controls="panel-flaca" data-song="flaca">
    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M8 5.5h8" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
      <path d="M12 5.5V2" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
      <path d="M7 21l5-7 5 7" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
      <circle cx="9" cy="17" r="2" stroke="currentColor" stroke-width="1.6"/>
      <circle cx="15" cy="17" r="2" stroke="currentColor" stroke-width="1.6"/>
    </svg>
    Flaca
  </button>

  <button class="tab-btn tab-afinador" role="tab" aria-selected="false" aria-controls="panel-afinador" data-song="afinador">
    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M12 3v12" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
      <circle cx="12" cy="18" r="3" stroke="currentColor" stroke-width="1.6"/>
      <path d="M12 3c2.2 0 4 1 5.5 2.3M12 3c-2.2 0-4 1-5.5 2.3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
    </svg>
    Afinador
  </button>
</nav>

<style>
  .tablist {
    display: flex;
    flex-wrap: wrap;
    gap: 4px 10px;
    margin: 36px 0 0;
    border-bottom: 1px solid rgba(239, 227, 206, 0.15);
  }

  .tab-btn {
    flex: 1 1 150px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 9px;
    background: transparent;
    border: none;
    border-bottom: 3px solid transparent;
    color: var(--marfil-tenue);
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 14px;
    padding: 14px 8px 16px;
    cursor: pointer;
    transition: color 0.25s ease, border-color 0.25s ease;
    border-radius: 6px 6px 0 0;
  }

  .tab-btn svg {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    opacity: 0.75;
    transition: opacity .25s ease;
  }

  .tab-btn:hover {
    color: var(--marfil);
    background: rgba(239, 227, 206, 0.04);
  }

  .tab-btn.tab-reloj.active { color: var(--oro-claro); border-color: var(--oro-viejo); }
  .tab-btn.tab-reloj.active svg { opacity: 1; }

  .tab-btn.tab-llorando.active { color: var(--azul-claro); border-color: var(--azul-llanto); }
  .tab-btn.tab-llorando.active svg { opacity: 1; }

  .tab-btn.tab-tratame.active { color: var(--rosa-claro); border-color: var(--rosa-suave); }
  .tab-btn.tab-tratame.active svg { opacity: 1; }

  .tab-btn.tab-ayer.active { color: var(--lila-claro); border-color: var(--lila-nostalgia); }
  .tab-btn.tab-ayer.active svg { opacity: 1; }

  .tab-btn.tab-amor.active { color: var(--oro-claro); border-color: var(--oro-viejo); }
  .tab-btn.tab-amor.active svg { opacity: 1; }

  .tab-btn.tab-valparaiso.active { color: var(--azul-claro); border-color: var(--azul-llanto); }
  .tab-btn.tab-valparaiso.active svg { opacity: 1; }

  .tab-btn.tab-afinador.active { color: var(--verde-claro); border-color: var(--verde-uke); }
  .tab-btn.tab-afinador.active svg { opacity: 1; }

  .tab-btn:focus-visible {
    outline: 2px solid var(--marfil);
    outline-offset: 2px;
  }

  @media (max-width: 480px) {
    .tab-btn {
      font-size: 12.5px;
      padding: 12px 4px 14px;
      gap: 6px;
    }
    .tab-btn svg {
      width: 15px;
      height: 15px;
    }
  }
</style>
